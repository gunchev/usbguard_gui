# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{cfg,ini,md,py,rst,toml,txt}]
indent_style = space
indent_size = 4

[*.{htm,html,js,json,xml,yaml,yml}]
indent_style = space
indent_size = 2

[{Makefile,*.go}]
indent_style = tab
