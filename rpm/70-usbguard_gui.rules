// Polkit rules for usbguard_gui
//
// Allows ALL local active console sessions to manage USB device
// authorization via the USBGuard D-Bus interface without a password prompt.
//
// Install to: /etc/polkit-1/rules.d/70-usbguard_gui.rules
//
// To allow only the users in the "wheel" group (i.e. local admins)
//   replace subject.active == true
//   with    subject.isInGroup("wheel")

polkit.addRule(function(action, subject) {
    var usbguardActions = [
        "org.usbguard.Devices1.applyDevicePolicy",
        "org.usbguard.Devices1.listDevices",
        "org.usbguard.Policy1.listRules",
        "org.usbguard.Policy1.appendRule",
        "org.usbguard.Policy1.removeRule",
        "org.usbguard.Policy1.getRule",
    ];
    if (usbguardActions.indexOf(action.id) !== -1 &&
            subject.active == true &&
            subject.local == true &&
            subject.active == true) {
        return polkit.Result.YES;
    }
});
